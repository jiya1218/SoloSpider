    "node-cron": "^3.0.3",
    "node-html-parser": "^6.1.13",
    "pino": "^9.1.0",
    "pino-pretty": "^11.0.0",
    "undici": "^6.19.2",
    "ws": "^8.20.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.18.1",
    "tsx": "^4.15.7",
    "typescript": "^5.5.4"
