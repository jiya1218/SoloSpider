{
  "name": "solospider-worker",
  "version": "1.0.0",
  "description": "SoloSpider background worker — crawling, AI prompt scanning, GEO scoring",
  "private": true,
  "type": "module",
  "main": "dist/worker.js",
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=1024' npx tsx watch src/worker.ts",
